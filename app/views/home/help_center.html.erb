<div class="w-full max-w-6xl mx-auto px-6 py-20">
  <div class="bg-white shadow-2xl rounded-[2.5rem] overflow-hidden border border-gray-200">
    <!-- Enhanced Header with Gradient and Animation -->
    <div class="bg-gradient-to-br from-gray-900 via-emerald-950 to-gray-900 px-8 py-20 text-center relative overflow-hidden">
      <!-- Animated background elements -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-500/20 via-transparent to-transparent"></div>
      <div class="absolute top-10 right-20 w-64 h-64 bg-emerald-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-10 left-20 w-64 h-64 bg-fuchsia-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-md border border-white/20 rounded-full mb-6">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span class="!text-white text-xs font-bold uppercase tracking-wider">Support Center</span>
        </div>
        <h1 class="text-4xl md:text-6xl font-extrabold text-white relative z-10 tracking-tight mb-4">Help Center</h1>
        <p class="mt-6 !text-white relative z-10 max-w-2xl mx-auto italic font-light text-lg leading-relaxed">Find answers to frequently asked questions and learn more about our luxury products.</p>
        <div class="mt-10 h-1.5 w-32 bg-gradient-to-r from-emerald-500 to-teal-400 mx-auto rounded-full relative z-10"></div>
      </div>
    </div>

    <div class="p-12 md:p-16 space-y-12">
      <!-- FAQ Sections - Single Column Layout -->
      <div class="space-y-10">
        <!-- Order & Shipping -->
        <section class="reveal">
          <div class="flex items-center mb-8 p-6 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-2xl border border-blue-200 shadow-md">
            <span class="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-500 text-white rounded-2xl flex items-center justify-center mr-6 shadow-lg flex-shrink-0">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
              </svg>
            </span>
            <div>
              <h2 class="text-3xl font-bold text-gray-900">Ordering & Shipping</h2>
              <p class="text-sm text-gray-600 mt-1">Delivery information and tracking</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-blue-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-blue-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-blue-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                How long does shipping take?
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">Processing typically takes 1-3 business days. Domestic shipping takes 3-5 days, while international shipping varies by location.</p>
            </div>
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-blue-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-blue-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-blue-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Can I track my order?
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">Yes! Once your order has shipped, you will receive a tracking number via email to monitor your luxury bundles.</p>
            </div>
          </div>
        </section>

        <!-- Product Care -->
        <section class="reveal">
          <div class="flex items-center mb-8 p-6 bg-gradient-to-r from-emerald-50 to-teal-50 rounded-2xl border border-emerald-200 shadow-md">
            <span class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-teal-500 text-white rounded-2xl flex items-center justify-center mr-6 shadow-lg flex-shrink-0">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </span>
            <div>
              <h2 class="text-3xl font-bold text-gray-900">Hair Care & Quality</h2>
              <p class="text-sm text-gray-600 mt-1">Maintenance tips and quality info</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-emerald-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-emerald-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                How should I maintain my bundles?
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">We recommend using sulfate-free products, regular deep conditioning, and avoiding excessive heat to preserve the natural lustre.</p>
            </div>
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-emerald-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-emerald-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Are these 100% human hair?
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">Absolutely. We only source 100% premium human hair that is thick from root to tip for a flawless finish.</p>
            </div>
          </div>
        </section>

        <!-- Payments -->
        <section class="reveal">
          <div class="flex items-center mb-8 p-6 bg-gradient-to-r from-amber-50 to-orange-50 rounded-2xl border border-amber-200 shadow-md">
            <span class="w-16 h-16 bg-gradient-to-br from-amber-500 to-orange-500 text-white rounded-2xl flex items-center justify-center mr-6 shadow-lg flex-shrink-0">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </span>
            <div>
              <h2 class="text-3xl font-bold text-gray-900">Payments & Security</h2>
              <p class="text-sm text-gray-600 mt-1">Secure transactions and payment methods</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-amber-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-amber-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-amber-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                What payment methods do you accept?
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">We accept all major credit cards and secure online payment gateways for your peace of mind.</p>
            </div>
          </div>
        </section>

        <!-- Policies -->
        <section class="reveal">
          <div class="flex items-center mb-8 p-6 bg-gradient-to-r from-purple-50 to-pink-50 rounded-2xl border border-purple-200 shadow-md">
            <span class="w-16 h-16 bg-gradient-to-br from-purple-500 to-pink-500 text-white rounded-2xl flex items-center justify-center mr-6 shadow-lg flex-shrink-0">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </span>
            <div>
              <h2 class="text-3xl font-bold text-gray-900">Our Policies</h2>
              <p class="text-sm text-gray-600 mt-1">Terms, conditions and refund policy</p>
            </div>
          </div>
          <div class="space-y-4">
            <div class="group p-8 bg-white rounded-2xl border border-gray-200 hover:border-purple-400 hover:shadow-xl transition-all duration-300 cursor-pointer">
              <h3 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition flex items-center gap-3">
                <svg class="w-6 h-6 text-gray-500 group-hover:text-purple-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                View Refund & Exchange Policy
              </h3>
              <p class="mt-4 text-base text-gray-700 leading-relaxed pl-9">Due to hygienic reasons, all sales are final. Learn more about our exchange eligibility on our policy page.</p>
              <%= link_to refund_policy_path, class: "mt-4 inline-flex items-center text-purple-600 font-bold text-sm hover:text-purple-800 transition group/link" do %>
                <span>Read Full Policy</span>
                <svg class="w-4 h-4 ml-1 transform group-hover/link:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                </svg>
              <% end %>
            </div>
          </div>
        </section>
      </div>

      <!-- Enhanced Still Need Help Section -->
      <section class="reveal relative bg-gradient-to-br from-emerald-50 via-white to-blue-50 rounded-[2.5rem] p-12 text-center overflow-hidden border border-gray-200">
        <!-- Animated background elements -->
        <div class="absolute top-10 right-20 w-64 h-64 bg-emerald-100/40 rounded-full blur-3xl animate-pulse-slow"></div>
        <div class="absolute bottom-10 left-20 w-64 h-64 bg-blue-100/40 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 2s;"></div>
        
        <div class="relative z-10">
          <div class="inline-flex items-center gap-2 px-6 py-3 bg-emerald-100/50 backdrop-blur-md border border-emerald-200 rounded-full mb-6">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            <span class="text-emerald-800 text-xs font-bold uppercase tracking-wider">Premium Support</span>
          </div>
          <h2 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-4">Still have questions?</h2>
          <p class="text-gray-700 mb-10 font-light text-lg max-w-xl mx-auto">Our dedicated concierge team is here to assist you with any inquiries about our luxury collections.</p>
          <div class="flex flex-col sm:flex-row justify-center gap-5">
            <%= link_to contact_us_path, class: "group px-12 py-5 bg-gradient-to-r from-emerald-600 to-emerald-500 text-white font-bold rounded-full hover:from-emerald-500 hover:to-emerald-400 transition-all duration-500 shadow-2xl hover:shadow-emerald-500/40 hover:scale-105 active:scale-95 flex items-center justify-center gap-2" do %>
              <span>Contact Concierge</span>
              <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            <% end %>
            <a href="mailto:support@fandisha.com" class="group px-12 py-5 bg-white text-gray-900 font-bold rounded-full hover:bg-gray-50 transition-all duration-300 border-2 border-gray-300 hover:border-emerald-400 flex items-center justify-center gap-2 shadow-md">
              <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
              <span>Email Support</span>
            </a>
          </div>
        </div>
      </section>
    </div>

    <div class="bg-gradient-to-r from-gray-50 via-white to-gray-50 px-8 py-8 text-center border-t border-gray-200 rounded-b-[2.5rem]">
      <%= link_to root_path, class: "text-gray-700 hover:text-emerald-600 font-bold transition flex items-center justify-center group" do %>
        <svg class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Home
      <% end %>
    </div>
  </div>
</div>

<style>
  /* Enhanced reveal animations */
  .reveal { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  .reveal-delay-2 { transition-delay: 200ms; }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.4; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.05); }
  }
  
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
</style>

<script>
  (function(){
    let io = null;
    function init(){
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window){
        io = new IntersectionObserver((entries)=>{
          entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('revealed'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        reveals.forEach(el=> io.observe(el));
      } else {
        reveals.forEach(el=> el.classList.add('revealed'));
      }
    }
    function cleanup(){
      if (io){ io.disconnect(); io = null; }
      document.querySelectorAll('.reveal').forEach(el=> el.classList.add('revealed'));
    }
    document.addEventListener('turbo:load', init);
    document.addEventListener('turbo:render', init);
    document.addEventListener('turbo:before-cache', cleanup);
  })();
</script>
