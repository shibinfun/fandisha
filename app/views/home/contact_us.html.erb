<div class="w-full max-w-6xl mx-auto px-6 py-20">
  <div class="bg-white shadow-2xl rounded-[2.5rem] overflow-hidden border border-gray-100">
    <!-- Enhanced Header with Gradient -->
    <div class="bg-gradient-to-br from-gray-900 via-emerald-950 to-gray-900 px-8 py-20 text-center relative overflow-hidden">
      <!-- Animated background elements -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-500/20 via-transparent to-transparent"></div>
      <div class="absolute top-10 right-20 w-64 h-64 bg-emerald-500/10 rounded-full blur-3xl animate-pulse-slow"></div>
      <div class="absolute bottom-10 left-20 w-64 h-64 bg-fuchsia-500/10 rounded-full blur-3xl animate-pulse-slow" style="animation-delay: 1s;"></div>
      
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 backdrop-blur-md border border-white/20 rounded-full mb-6">
          <svg class="w-4 h-4 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
          </svg>
            <span class="!text-white text-xs font-bold uppercase tracking-wider">Concierge Service</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold text-white relative z-10 tracking-tight mb-4">Contact Us</h1>
          <p class="mt-6 !text-white relative z-10 max-w-2xl mx-auto italic font-light text-lg leading-relaxed">We are here to help you elevate your luxury standards. Reach out to our dedicated team for any inquiries.</p>
        <div class="mt-10 h-1.5 w-32 bg-gradient-to-r from-emerald-500 to-teal-400 mx-auto rounded-full relative z-10"></div>
      </div>
    </div>

    <div class="p-12 md:p-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Contact Information -->
        <div class="reveal">
          <h2 class="text-3xl font-bold text-gray-900 mb-10 tracking-tight flex items-center gap-3">
            <span class="w-1.5 h-8 bg-emerald-500 rounded-full"></span>
            Get in Touch
          </h2>
          
          <div class="space-y-8">
            <!-- Email -->
            <div class="group flex items-start p-6 bg-gradient-to-r from-emerald-50/50 to-transparent rounded-2xl hover:shadow-lg hover:shadow-emerald-500/10 transition-all duration-300 border border-transparent hover:border-emerald-200">
              <div class="w-14 h-14 bg-gradient-to-br from-emerald-500 to-teal-400 text-white rounded-2xl flex items-center justify-center mr-6 flex-shrink-0 shadow-lg shadow-emerald-500/30 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Email Us</h3>
                <a href="mailto:support@fandisha.com" class="text-xl text-gray-900 font-bold hover:text-emerald-600 transition block">support@fandisha.com</a>
                <p class="text-sm text-gray-500 mt-2 flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Response within 24-48 hours
                </p>
              </div>
            </div>

            <!-- Business Hours -->
            <div class="group flex items-start p-6 bg-gradient-to-r from-blue-50/50 to-transparent rounded-2xl hover:shadow-lg hover:shadow-blue-500/10 transition-all duration-300 border border-transparent hover:border-blue-200">
              <div class="w-14 h-14 bg-gradient-to-br from-blue-500 to-indigo-400 text-white rounded-2xl flex items-center justify-center mr-6 flex-shrink-0 shadow-lg shadow-blue-500/30 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Business Hours</h3>
                <p class="text-xl text-gray-900 font-bold">Monday – Friday</p>
                <p class="text-base text-gray-600 mt-1">9:00 AM – 6:00 PM (GMT)</p>
              </div>
            </div>

            <!-- Location -->
            <div class="group flex items-start p-6 bg-gradient-to-r from-amber-50/50 to-transparent rounded-2xl hover:shadow-lg hover:shadow-amber-500/10 transition-all duration-300 border border-transparent hover:border-amber-200">
              <div class="w-14 h-14 bg-gradient-to-br from-amber-500 to-orange-400 text-white rounded-2xl flex items-center justify-center mr-6 flex-shrink-0 shadow-lg shadow-amber-500/30 group-hover:scale-110 transition-transform duration-300">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-2">Location</h3>
                <p class="text-xl text-gray-900 font-bold">Luxury Distribution Center</p>
                <p class="text-base text-gray-600">Premium Hair Care HQ</p>
              </div>
            </div>
          </div>

          <!-- Enhanced Social Proof/Quote -->
          <div class="mt-12 relative p-10 bg-gradient-to-br from-stone-50 to-white rounded-[2rem] border border-stone-200 shadow-lg overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-100/30 rounded-full blur-2xl translate-x-1/2 -translate-y-1/2"></div>
            <div class="relative z-10">
              <svg class="w-10 h-10 text-emerald-500 mb-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.664-3.995 5.877v4.623c0 2.617-1.381 4.349-3.983 5.349zm-14 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.994 2.151c-2.432.917-3.995 3.664-3.995 5.877v4.623c0 2.617-1.381 4.349-3.983 5.349z"/>
              </svg>
              <p class="text-gray-700 italic font-light leading-relaxed text-lg">
                We understand that your crown is your pride. Our concierge service is dedicated to ensuring your experience with Fandisha is as seamless as our blends.
              </p>
            </div>
          </div>
        </div>

        <!-- Enhanced Contact Form -->
        <div class="reveal reveal-delay-2">
          <div class="relative bg-gradient-to-br from-stone-50 via-white to-stone-50 p-10 rounded-[2.5rem] border border-stone-200 shadow-xl overflow-hidden">
            <!-- Decorative elements -->
            <div class="absolute top-0 right-0 w-48 h-48 bg-emerald-100/30 rounded-full blur-3xl translate-x-1/2 -translate-y-1/2"></div>
            <div class="absolute bottom-0 left-0 w-48 h-48 bg-amber-100/30 rounded-full blur-3xl -translate-x-1/2 translate-y-1/2"></div>
            
            <div class="relative z-10">
              <h2 class="text-3xl font-bold text-gray-900 mb-8 tracking-tight flex items-center gap-3">
                <svg class="w-8 h-8 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Send a Message
              </h2>
              <%= form_with model: @inquiry, url: contact_us_path, class: "space-y-6" do |f| %>
                <% if @inquiry.errors.any? %>
                  <div class="bg-gradient-to-r from-red-50 to-red-100 text-red-800 p-6 rounded-2xl text-sm mb-6 border border-red-200 shadow-md">
                    <div class="flex items-start gap-3">
                      <svg class="w-6 h-6 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                      </svg>
                      <div>
                        <p class="font-bold mb-2">Please correct the following errors:</p>
                        <ul class="list-disc list-inside space-y-1">
                          <% @inquiry.errors.full_messages.each do |msg| %>
                            <li><%= msg %></li>
                          <% end %>
                        </ul>
                      </div>
                    </div>
                  </div>
                <% end %>

                <div class="grid grid-cols-1 gap-6">
                  <div class="group">
                    <%= f.label :name, "Full Name", class: "block text-sm font-bold text-gray-700 mb-2 ml-1" %>
                    <div class="relative">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 group-focus-within:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                      </div>
                      <%= f.text_field :name, placeholder: "E.g. Jane Doe", class: "w-full pl-12 pr-4 py-4 bg-white border-2 border-gray-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none font-medium placeholder-gray-400" %>
                    </div>
                  </div>
                  
                  <div class="group">
                    <%= f.label :email, "Email Address", class: "block text-sm font-bold text-gray-700 mb-2 ml-1" %>
                    <div class="relative">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 group-focus-within:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"></path>
                        </svg>
                      </div>
                      <%= f.email_field :email, placeholder: "jane@example.com", class: "w-full pl-12 pr-4 py-4 bg-white border-2 border-gray-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none font-medium placeholder-gray-400" %>
                    </div>
                  </div>
                  
                  <div class="group">
                    <%= f.label :subject, "Subject", class: "block text-sm font-bold text-gray-700 mb-2 ml-1" %>
                    <div class="relative">
                      <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400 group-focus-within:text-emerald-500 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                        </svg>
                      </div>
                      <%= f.select :subject, ["Order Inquiry", "Product Question", "Wholesale Inquiry", "Other"], { prompt: "Select a subject" }, class: "w-full pl-12 pr-4 py-4 bg-white border-2 border-gray-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none font-medium appearance-none cursor-pointer" %>
                      <div class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                      </div>
                    </div>
                  </div>
                  
                  <div class="group">
                    <%= f.label :message, "Message", class: "block text-sm font-bold text-gray-700 mb-2 ml-1" %>
                    <div class="relative">
                      <%= f.text_area :message, rows: 5, placeholder: "How can we help you?", class: "w-full px-4 py-4 bg-white border-2 border-gray-200 rounded-2xl focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500 transition-all outline-none font-medium placeholder-gray-400 resize-none" %>
                    </div>
                  </div>
                </div>
                
                <%= f.submit "Send Concierge Request", class: "w-full py-5 bg-gradient-to-r from-gray-900 to-gray-800 text-white font-bold rounded-2xl hover:from-emerald-600 hover:to-emerald-500 transition-all duration-500 shadow-xl hover:shadow-emerald-500/40 active:scale-[0.98] cursor-pointer flex items-center justify-center gap-2 group" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="bg-gradient-to-r from-gray-50 via-stone-50 to-gray-50 px-8 py-8 text-center border-t border-gray-100 rounded-b-[2.5rem]">
      <%= link_to root_path, class: "text-gray-600 hover:text-emerald-600 font-bold transition flex items-center justify-center group" do %>
        <svg class="w-5 h-5 mr-2 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Home
      <% end %>
    </div>
  </div>
</div>

<style>
  /* Enhanced reveal animations */
  .reveal { opacity: 0; transform: translateY(30px); transition: all 1s cubic-bezier(0.16, 1, 0.3, 1); }
  .reveal.revealed { opacity: 1; transform: translateY(0); }
  .reveal-delay-2 { transition-delay: 200ms; }
  
  @keyframes pulse-slow {
    0%, 100% { opacity: 0.4; transform: translateX(50%) translateY(-50%) scale(1); }
    50% { opacity: 0.6; transform: translateX(50%) translateY(-50%) scale(1.05); }
  }
  
  .animate-pulse-slow { animation: pulse-slow 8s ease-in-out infinite; }
</style>

<script>
  (function(){
    let io = null;
    function init(){
      const reveals = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window){
        io = new IntersectionObserver((entries)=>{
          entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('revealed'); io.unobserve(e.target); } });
        }, { threshold: 0.1 });
        reveals.forEach(el=> io.observe(el));
      } else {
        reveals.forEach(el=> el.classList.add('revealed'));
      }
    }
    function cleanup(){
      if (io){ io.disconnect(); io = null; }
      document.querySelectorAll('.reveal').forEach(el=> el.classList.add('revealed'));
    }
    document.addEventListener('turbo:load', init);
    document.addEventListener('turbo:render', init);
    document.addEventListener('turbo:before-cache', cleanup);
  })();
</script>
