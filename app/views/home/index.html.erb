            <div class="group flex items-start p-5 bg-white rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 border border-gray-100">
              <div class="w-3 h-3 bg-emerald-500 rounded-full mt-1.5 mr-5 flex-shrink-0 group-hover:scale-125 transition-transform"></div>
              <p class="text-gray-800 font-semibold">Avoid over-processing the hair</p>
